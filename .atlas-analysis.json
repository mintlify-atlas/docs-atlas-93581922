  "keyFeatures": [
    "Strong static type system with full type inference",
    "Compiles to Erlang (BEAM VM) and JavaScript",
    "Friendly, readable error messages",
    "Built-in formatter and language server (LSP)",
    "Seamless interop with Erlang/Elixir and JavaScript ecosystems",
    "Package manager integrated with Hex.pm",
    "Immutable data and functional programming patterns",
    "Pattern matching and custom types",
    "No null values or runtime type errors"
  ],
  "publicApiSurface": [
    "gleam new <project>",
    "gleam build [--target erlang|javascript]",
    "gleam run [--target] [--module]",
    "gleam test [--target] [--runtime]",
    "gleam check",
    "gleam format [--check]",
    "gleam fix",
    "gleam add <package> [--dev]",
    "gleam remove <package>",
    "gleam deps list|download|outdated|update|tree",
    "gleam publish [--replace] [-y]",
    "gleam docs build|publish|remove",
    "gleam export erlang-shipment|hex-tarball|javascript-prelude|typescript-prelude|package-interface",
    "gleam update [packages...]",
    "gleam clean",
    "gleam shell",
    "gleam lsp",
    "gleam hex authenticate|retire|unretire|revert|owner"
  ]
